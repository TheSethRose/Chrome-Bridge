{
  "manifest_version": 3,
  "name": "Chrome Bridge",
  "version": "0.1.0",
  "description": "A local CLI bridge for inspecting and operating Chrome with CDP.",
  "key": "",
  "permissions": [
    "bookmarks",
    "cookies",
    "debugger",
    "downloads",
    "history",
    "management",
    "nativeMessaging",
    "sessions",
    "sidePanel",
    "storage",
    "tabGroups",
    "tabs",
    "topSites",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Chrome Bridge status"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "minimum_chrome_version": "125"
}
